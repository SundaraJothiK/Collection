package Collections;
import java.util.*;
public class Queue1 {
	public static void main(String[] args) {
        Queue<Integer> q =new LinkedList<>();
		q.add(3);
		q.add(10);
		q.add(1);
		q.add(4);
		System.out.println("Head is "+q.peek());
		System.out.println("Removed "+q.poll());
		System.out.println("Removed "+q.remove());
		System.out.println("Head is "+q.peek());
		System.out.println("size is "+q.size());

	}

}
